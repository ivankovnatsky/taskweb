# TaskWeb configuration
# Copy this file to .env and adjust as needed.

# Path to Taskwarrior 3 data directory (contains taskchampion.sqlite3)
# Default: ~/.local/share/task
# TASKDATA=~/.local/share/task

# Secret key for session cookies (random string, persists sessions across restarts)
# If unset, a random key is generated on each startup (sessions lost on restart)
# TASKWEB_SECRET_KEY=change-me-to-something-random
